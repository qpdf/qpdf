#!/usr/bin/env perl
require 5.008;
use warnings;
use strict;

unshift(@INC, '.');
require qpdf_test_helpers;

chdir("qpdf") or die "chdir testdir failed: $!\n";

require TestDriver;

cleanup();

delete $ENV{'QPDF_DEDUPE_DEBUG'};

my $td = new TestDriver('deduplicate-image-XObjects');

my $n_tests = 4;

# ----------------------------------------------------------------------
# Test: Deduplicate image XObjects
# ----------------------------------------------------------------------

$td->runtest("deduplicate image XObjects",
             {$td->COMMAND => "qpdf --static-id --deduplicate-image-xobjects --stream-data=uncompress dedupe-in.pdf a.pdf"},
             {$td->STRING => "", $td->EXIT_STATUS => 0},
             $td->NORMALIZE_NEWLINES);

$td->runtest("check output",
             {$td->FILE => "a.pdf"},
             {$td->FILE => "dedupe-out.pdf"});

$td->runtest("deduplicate images in deduplicated file",
             {$td->COMMAND => "qpdf --static-id --deduplicate-image-xobjects --stream-data=uncompress a.pdf b.pdf"},
             {$td->STRING => "", $td->EXIT_STATUS => 0},
             $td->NORMALIZE_NEWLINES);

$td->runtest("check idempotence",
             {$td->FILE => "b.pdf"},
             {$td->FILE => "dedupe-out.pdf"});

cleanup();
$td->report($n_tests);
