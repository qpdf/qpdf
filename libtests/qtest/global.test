#!/usr/bin/env perl
require 5.008;
use warnings;
use strict;


chdir("global") or die "chdir testdir failed: $!\n";

require TestDriver;


my $td = new TestDriver('global');

my $n_tests = 3;

$td->runtest("global limits",
             {$td->COMMAND => "global 0 -"},
             {$td->FILE => "test0.out", $td->EXIT_STATUS => 0},
             $td->NORMALIZE_NEWLINES);

$td->runtest("global filter limits/ options",
             {$td->COMMAND => "global 1 -"},
             {$td->STRING => "test 1 done\n", $td->EXIT_STATUS => 0},
             $td->NORMALIZE_NEWLINES);

$td->runtest("C-API global setters",
             {$td->COMMAND => "global 2 -"},
             {$td->STRING => "test 2 done\n", $td->EXIT_STATUS => 0},
             $td->NORMALIZE_NEWLINES);

$td->report($n_tests);
